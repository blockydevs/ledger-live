{
  "name": "@devtools/feature-flags",
  "version": "0.3.1",
  "private": true,
  "description": "Ledger Live feature flags' Devtools",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "scripts": {
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'jest/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
