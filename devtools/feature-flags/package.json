    "@testing-library/user-event": "catalog:",
    "@types/jest": "catalog:",
    "@types/react": "catalog:",
    "jest": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "@swc/jest": "catalog:",
    "@swc/core": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "@ledgerhq/lumen-ui-react": "catalog:",
    "@ledgerhq/lumen-design-core": "catalog:",
    "@radix-ui/react-switch": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19",
    "@ledgerhq/lumen-design-core": "catalog:",
    "@ledgerhq/lumen-ui-react": "catalog:",
    "@radix-ui/react-switch": "catalog:"
  }
