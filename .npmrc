shared-workspace-lockfile=true
enable-pre-post-scripts=true
hoist=false
strict-peer-dependencies=false
dedupe-peer-dependents=false
auto-install-peers=false
save-exact=true

public-hoist-pattern[]=@nx/*
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*oxlint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/react
public-hoist-pattern[]=react-native
public-hoist-pattern[]=tailwindcss
public-hoist-pattern[]=*@opentui*

# Hoisted so @datadog/electron-sdk's DatadogWebpackPlugin can resolve dd-trace's
# transitive deps when copying them into the packaged build.
public-hoist-pattern[]=dc-polyfill
public-hoist-pattern[]=import-in-the-middle
public-hoist-pattern[]=acorn
public-hoist-pattern[]=acorn-import-attributes
public-hoist-pattern[]=cjs-module-lexer
public-hoist-pattern[]=module-details-from-path


