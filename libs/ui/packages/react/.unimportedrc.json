{
  "entry": [
    "src/index.ts",
    "src/pre-ldls/index.ts",
    "src/styles/index.ts",
    "src/assets/fonts.ts",
    "src/assets/icons.ts",
    "src/assets/cryptoIcons.ts",
    "src/components/animations/GlitchText/index.tsx"
  ],
  "extensions": [
    ".ts",
    ".js",
    ".jsx",
    ".tsx"
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/*.stories.*",
    "**/*.test.*"
  ],
  "ignoreUnimported": [
    "src/assets/images/images.d.ts",
    "src/components/Table/stories.helper.tsx",
    "src/components/helpers.ts",
    "src/components/navigation/Aside/stories.helper.tsx",
    "src/helpers.types.ts",
    "src/pre-ldls/components/sharedStoryBook.tsx"
  ],
  "ignoreUnresolved": [
    "@emotion/is-prop-valid",
    "@emotion/stylis",
    "@emotion/unitless",
    "@jest/expect-utils",
    "@jest/get-type",
    "hoist-non-react-statics",
    "jest-util",
    "scheduler",
    "shallowequal"
  ],
  "ignoreUnused": [
    "react",
    "react-dom",
    "styled-components"
  ]
}